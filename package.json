{
  "name": "yaasl",
  "version": "0.15.0-alpha.1",
  "description": "yet another atomic store library",
  "author": "PrettyCoffee",
  "homepage": "https://github.com/PrettyCoffee/yaasl",
  "license": "MIT",
  "workspaces": [
    "packages/utils",
    "packages/core",
    "packages/devtools",
    "packages/react",
    "packages/preact",
    "demo/*",
    "docs/"
  ],
  "scripts": {
    "start": "cd ./demo/react && npm run start",
    "build": "npm run build --workspaces",
    "test": "vitest run",
    "test:coverage": "npm run test -- --coverage",
    "test:watch": "vitest watch",
    "lint": "eslint",
    "lint:fix": "npm run lint -- --fix",
    "validate": "npm run validate --workspaces",
    "docs": "npm run -w docs start",
    "docs:generate": "node scripts/generate-docs.mjs",
    "publish": "node ./scripts/publish.mjs",
    "upgrade": "ncu --deep -u -t minor -f !@yaasl/*",
    "upgrade:latest": "npm run upgrade -- -t latest",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@pretty-cozy/eslint-config": "0.9.0",
    "@pretty-cozy/release-tools": "0.9.0",
    "@vitest/coverage-v8": "4.0.18",
    "enquirer": "2.4.1",
    "happy-dom": "20.8.9",
    "husky": "9.1.7",
    "npm-check-updates": "19.3.2",
    "npm-run-all2": "8.0.4",
    "rimraf": "6.1.2",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
