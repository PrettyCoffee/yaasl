{
  "name": "yaasl",
  "version": "0.15.0-alpha.1",
  "description": "yet another atomic store library",
  "author": "PrettyCoffee",
  "homepage": "https://github.com/PrettyCoffee/yaasl",
  "license": "MIT",
  "workspaces": [
    "packages/utils",
    "packages/core",
    "packages/devtools",
    "packages/react",
    "packages/preact",
    "demo/*",
    "docs/"
  ],
  "scripts": {
    "start": "cd ./demo/react && pnpm run start",
    "build": "pnpm run --filter='./**' build",
    "test": "vitest run",
    "test:coverage": "pnpm run test --coverage",
    "test:watch": "vitest watch",
    "lint": "eslint",
    "lint:fix": "pnpm run lint --fix",
    "validate": "pnpm run validate --workspaces",
    "docs": "pnpm run --filter='./docs' start",
    "docs:generate": "node scripts/generate-docs.mjs",
    "publish": "node ./scripts/publish.mjs",
    "upgrade": "ncu --deep -u -t minor -f !@yaasl/*",
    "upgrade:latest": "pnpm run upgrade -t latest",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.3",
    "@commitlint/config-conventional": "20.5.3",
    "@pretty-cozy/eslint-config": "0.9.0",
    "@pretty-cozy/release-tools": "0.9.0",
    "@vitest/coverage-v8": "4.1.10",
    "enquirer": "2.4.1",
    "eslint": "9.39.4",
    "happy-dom": "20.10.6",
    "husky": "9.1.7",
    "npm-check-updates": "21.0.3",
    "npm-run-all2": "8.0.4",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
